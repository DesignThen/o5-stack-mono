{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream-with-experimental-timestamps",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", ".vercel/output/**"]
    },
    "web#build": {
      "dependsOn": ["^build"],
      "env": [
        "VITE_CLERK_PUBLISHABLE_KEY",
        "VITE_CONVEX_SITE_URL",
        "VITE_CONVEX_URL",
        "VITE_POSTHOG_HOST",
        "VITE_POSTHOG_KEY",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_ORG",
        "VITE_SENTRY_PROJECT"
      ],
      "passThroughEnv": [
        "CLERK_SECRET_KEY",
        "SENTRY_AUTH_TOKEN",
        "CONVEX_DEPLOY_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", ".vercel/output/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "typegen": {
      "dependsOn": ["^typegen"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
