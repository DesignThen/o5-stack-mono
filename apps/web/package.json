{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.1.7",
    "@clerk/ui": "^1.6.7",
    "@convex-dev/react-query": "^0.1.0",
    "@posthog/react": "^1.9.0",
    "@repo/ui": "workspace:*",
    "@sentry/tanstackstart-react": "^10.50.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.49",
    "@tanstack/router-plugin": "^1.167.27",
    "convex": "^1.36.1",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^1.11.0",
    "nitro": "latest",
    "posthog-js": "^1.372.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.0",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
